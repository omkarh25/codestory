# ─── codeStory LLM Configuration ─────────────────────────────────────────────
# Copy this file to llm.env and fill in your API key(s)
# llm.env is gitignored — never commit your actual keys

# Anthropic (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MiniMax (optional alternative — uncomment and configure in config.json)
# MINIMAX_API_KEY=your_minimax_api_key_here
