{
    "codestory": {
        "repo_path": ".",
        "db_path": ".codestory/codestory.db",
        "output_dir": ".codestory/assets",
        "haiku": {
            "provider": "anthropic",
            "model": "claude-haiku-4-5-20251001",
            "depth": "git_commit",
            "max_per_run": 12,
            "batch_size": 3
        },
        "episode": {
            "provider": "anthropic",
            "model": "claude-haiku-4-5-20251001",
            "depth": "git_commit",
            "haikus_per_episode": 10
        },
        "yt_shorts": {
            "slide_duration": 2.5,
            "verdict_duration": 4.0,
            "fps": 30,
            "resolution": "1920x1080",
            "output_dir": ".codestory/assets/videos"
        },
        "oldest_first": true
    }
}
